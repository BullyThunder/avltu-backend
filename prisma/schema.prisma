// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  name      String
  password  String
  createdAt DateTime @default(now())
  orders    Order[]
}

model Order {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())
  title     String // Название груза, например "Цветы" или "Запчасти"
  weight    Float
  status    String   @default("PENDING")

  origin      String
  destination String
  // Поле для хранения ID владельца (реальная колонка в таблице БД)
  userId      Int

  // Настройка связи: 
  // fields указывает на поле в этой модели (userId)
  // references указывает на поле в модели User (id)
  author User @relation(fields: [userId], references: [id])
}
